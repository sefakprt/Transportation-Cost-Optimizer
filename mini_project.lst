  49  * ------------------------------------------------------------------
  50  * COST CALCULATION
  51  * ------------------------------------------------------------------
  52   
  53  Parameter TotalSeaCost(i,j);
  54  * EUAC is 8% of Investment + Shipping Cost
  55  TotalSeaCost(i,j) = SeaTransCost(i,j) + (0.08 * InvestCost(i,j));
  56   
  57  Parameter CostOpt1(i,j) "Option 1: Rail Only";
  58  CostOpt1(i,j) = RailCost(i,j);
  59   
  60  Parameter CostOpt2(i,j) "Option 2: Water Only (Rail if Water 0easible)";
  61  * Use Water cost if available, otherwise use Rail cost
  62  CostOpt2(i,j) = TotalSeaCost(i,j);
  63  CostOpt2(i,j)$(TotalSeaCost(i,j) = 0) = RailCost(i,j);
  64   
  65  Parameter CostOpt3(i,j) "Option 3: Cheapest of Rail or Water";
  66  CostOpt3(i,j) = min(RailCost(i,j), TotalSeaCost(i,j));
  67   
  68  * ------------------------------------------------------------------
  69  * MODEL DEFINITION
  70  * ------------------------------------------------------------------
  71   
  72  Variables
  73       x(i,j)      Amount shipped from source i to market j
  74       z           Total Cost;
  75   
  76  Positive Variable x;
  77   
  78  Parameters
  79       CurrentCost(i,j)   Active cost parameter for the solver;
  80   
  81  Equations
  82       ObjFunction       Minimize total transportation cost
  83       SupplyConst(i)    Do not exceed supply at sources
  84       DemandConst(j)    Satisfy demand at markets;
  85   
  86  ObjFunction..        z =e= sum((i,j), CurrentCost(i,j) * x(i,j));
  87   
  88  SupplyConst(i)..     sum(j, x(i,j)) =l= Supply(i);
  89   
  90  DemandConst(j)..     sum(i, x(i,j)) =g= Demand(j);
  91   
  92  Model TransportModel /all/;
  93   
  94  * ------------------------------------------------------------------
  95  * QUESTION 1: SOLVING ALL OPTIONS
  96  * ------------------------------------------------------------------
  97   
  98  * --- Option 1: Rail Only ---
  99  CurrentCost(i,j) = CostOpt1(i,j);
 100  Solve TransportModel using lp minimizing z;
 101  Display "--- Results for Option 1 (Rail Only) ---", z.l, x.l;
 102   
 103  * --- Option 2: Maritime Preferred ---
 104  CurrentCost(i,j) = CostOpt2(i,j);
 105  Solve TransportModel using lp minimizing z;
 106  Display "--- Results for Option 2 (Maritime Preferred) ---", z.l, x.l;
 107   
 108  * --- Option 3: Best of Both ---
 109  CurrentCost(i,j) = CostOpt3(i,j);
 110  Solve TransportModel using lp minimizing z;
 111  Display "--- Results for Option 3 (Best Strategy) ---", z.l, x.l;
 112   
 113  * ------------------------------------------------------------------
 114  * PREPARING FOR QUESTIONS 2-5
 115  * Note: We use Option 3 (Best Strategy) as the baseline for improvements.
 116  * ------------------------------------------------------------------
 117   
 118  * ------------------------------------------------------------------
 119  * QUESTION 2: PRE-ASSIGNED SHIPMENTS
 120  * Keep S1-M2, S3-M1, S3-M2 at 6 million tons.
 121  * ------------------------------------------------------------------
 122   
 123  * Reset constraints
 124  x.lo(i,j) = 0;
 125  x.up(i,j) = 0;
 126   
 127  * Fix specific variables
 128  x.fx('1','2') = 6;
 129  x.fx('3','1') = 6;
 130  x.fx('3','2') = 6;
 131   
 132  CurrentCost(i,j) = CostOpt3(i,j);
 133  Solve TransportModel using lp minimizing z;
 134  Display "--- Answer to Q2: Fixed Shipments ---", z.l, x.l;
 135   
 136  * ------------------------------------------------------------------
 137  * SENSITIVITY ANALYSIS (For Q3, Q4, Q5)
 138  * Resetting to Optimal Option 3 to get Marginal values
 139  * ------------------------------------------------------------------
 140  x.lo(i,j) = 0;
 141  x.up(i,j) = 0;
 142  CurrentCost(i,j) = CostOpt3(i,j);
 143  Solve TransportModel using lp minimizing z;
 144   
 145  * ------------------------------------------------------------------
 146  * QUESTION 3: Source 4 -> Market 8 Relationship
 147  * Look at Reduced Cost (x.m) for x('4','8')
 148  * ------------------------------------------------------------------
 149  Display "--- Answer to Q3: Cost to justify S4-M8 ---", x.m;
 150   
 151  * ------------------------------------------------------------------
 152  * QUESTION 4: Source 2 -> Market 7 by Rail
 153  * Check if Rail cost is used in Opt 3. If not, look at difference.
 154  * ------------------------------------------------------------------
 155  Parameter RailCheck_S2_M7;
 156  RailCheck_S2_M7 = RailCost('2','7');
 157  Display "--- Answer to Q4: Check Rail Cost S2-M7 ---", RailCheck_S2_M7, x.l;
 158   
 159  * ------------------------------------------------------------------
 160  * QUESTION 5: Supply Variation
 161  * Look at Shadow Prices (Marginals) of Supply Constraints
 162  * ------------------------------------------------------------------
 163  Display "--- Answer to Q5: Supply Shadow Prices ---", SupplyConst.m;


